{
  "name": "@stratum/discord-bot",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    "./qa": {
      "types": "./dist/qa-search.d.ts",
      "default": "./dist/qa-search.js"
    },
    "./store": {
      "types": "./dist/db.d.ts",
      "default": "./dist/db.js"
    },
    "./sqlite-store": {
      "types": "./dist/sqlite-store.d.ts",
      "default": "./dist/sqlite-store.js"
    },
    "./freshness": {
      "types": "./dist/freshness.d.ts",
      "default": "./dist/freshness.js"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@stratum/gh-client": "workspace:*",
    "@stratum/kb-core": "workspace:*",
    "@stratum/llm": "workspace:*",
    "better-sqlite3": "^12.11.1",
    "discord.js": "^14.26.4",
    "js-yaml": "^4.2.0",
    "pino": "^10.3.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/js-yaml": "^4.0.9"
  }
}
