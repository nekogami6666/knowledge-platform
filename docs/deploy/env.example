# stratum bot secrets — Claude on AWS + Discord(ADR-0009 / ADR-0010 §9.1)。
# deploy.sh が初回にこれを ~/stratum/stratum.env へコピーします(chmod 600)。
# 値はクォート不要。= の後にそのまま貼る。REPLACE_ME を実値に置き換えること。
# このファイル(.example)に本物のシークレットを書かないこと(コミットされます)。

# Claude on AWS(全 AI 操作はこの 4 変数で動く・ADR-0009)
CLAUDE_CODE_USE_ANTHROPIC_AWS=1
# ワークスペース API キー: AEAA… で始まる ~131 字。ドット無し。
#   ※ MT… で始まりドット2個・~72字なら Discord トークンの取り違えです。
ANTHROPIC_AWS_API_KEY=REPLACE_ME_aws_workspace_key
ANTHROPIC_AWS_WORKSPACE_ID=REPLACE_ME_wrkspc_id
AWS_REGION=ap-northeast-1

# Discord
DISCORD_TOKEN=REPLACE_ME_discord_bot_token
# スラッシュコマンド登録先サーバー(ギルド)ID。未指定だとグローバル登録(反映に最大1時間)。
DISCORD_GUILD_ID=REPLACE_ME_guild_id

# --- 任意(機能単位で有効化) ---

# GitHub 書き込み(👍 代理マージ / 💡 capture / voice-memo の PR + gap-tracker/freshness の
# question commit・KB PR)。GitHub App trio(推奨・組織所有)か GITHUB_TOKEN(PAT)のどちらか。
# ★本番は App 推奨(Actions と同じ値・ADR-0013 D4 の hybrid: PR/write=App / clone=PAT)。
# GITHUB_APP_ID=REPLACE_ME_app_id
# GITHUB_APP_PRIVATE_KEY=REPLACE_ME_pem_full_or_\n_embedded
# GITHUB_APP_INSTALLATION_ID=REPLACE_ME_installation_id
# または PAT(暫定): GITHUB_TOKEN=REPLACE_ME_fine_grained_pat

# voice-memo の文字起こし(ADR-0015 D3)。未設定なら voice-memo は受付のみ(文字起こしされない)。
# knowledge-platform 専用に新規発行(QB-Meeting-Ops と分離)。
# OPENAI_API_KEY=REPLACE_ME_openai_key

# VC 録音入口(ADR-0020)。RECORDER_URL は compose 内部ネットワーク。RECORDER_DISCORD_TOKEN は
# 録音専用 bot(メイン bot とは別の新規 App・ADR-0020 D2)。両方揃えて `--profile vc` で有効。
# RECORDER_URL=http://recorder:9488
# RECORDER_DISCORD_TOKEN=REPLACE_ME_recorder_bot_token

# --- gap-tracker / freshness-checker(systemd)も同じ stratum.env を EnvironmentFile で共用 ---
# gap-tracker の回答依頼を投稿する Discord webhook(§6.5)。real 稼働に必須。
# DISCORD_GAP_WEBHOOK=REPLACE_ME_gap_channel_webhook
# extractor/gap/freshness の #stratum-ops 通知先(任意だが本番推奨)。
# DISCORD_OPS_WEBHOOK=REPLACE_ME_ops_channel_webhook
# ※ GAP_TRACKER_REAL / FRESHNESS_REAL はここではなく install-timers.sh --real で unit 側に立てる。
