# stratum bot secrets — Claude on AWS + Discord(ADR-0009 / ADR-0010 §9.1)。
# deploy.sh が初回にこれを ~/stratum/stratum.env へコピーします(chmod 600)。
# 値はクォート不要。= の後にそのまま貼る。REPLACE_ME を実値に置き換えること。
# このファイル(.example)に本物のシークレットを書かないこと(コミットされます)。

# Claude on AWS(全 AI 操作はこの 4 変数で動く・ADR-0009)
CLAUDE_CODE_USE_ANTHROPIC_AWS=1
# ワークスペース API キー: AEAA… で始まる ~131 字。ドット無し。
#   ※ MT… で始まりドット2個・~72字なら Discord トークンの取り違えです。
ANTHROPIC_AWS_API_KEY=REPLACE_ME_aws_workspace_key
ANTHROPIC_AWS_WORKSPACE_ID=REPLACE_ME_wrkspc_id
AWS_REGION=ap-northeast-1

# Discord
DISCORD_TOKEN=REPLACE_ME_discord_bot_token
# スラッシュコマンド登録先サーバー(ギルド)ID。未指定だとグローバル登録(反映に最大1時間)。
DISCORD_GUILD_ID=REPLACE_ME_guild_id
